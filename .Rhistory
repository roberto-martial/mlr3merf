)
at_knn$id = "KNN_tuned"
learners = list(l_merf, l_feat, l_glm, at_knn)
# =========================
# 3. BENCHMARK MANUEL (SAFE)
# =========================
results_list = list()
for (task in tasks) {
cat("\n===== Task:", task$id, "=====\n")
# Resampling spécifique à chaque task
cv5 = rsmp("cv", folds = 5)
cv5$instantiate(task)
for (learner in learners) {
cat("-> Learner:", learner$id, "\n")
for (i in seq_len(cv5$iters)) {
# 🔥 FIX CRUCIAL
train_ids = task$row_ids[cv5$train_set(i)]
test_ids  = task$row_ids[cv5$test_set(i)]
# Clone pour éviter contamination entre folds
learner_i = learner$clone(deep = TRUE)
# Train
suppressWarnings(
learner_i$train(task, row_ids = train_ids)
)
# Predict
pred = learner_i$predict(task, row_ids = test_ids)
# Score
rmse = pred$score(msr("regr.rmse"))
results_list[[length(results_list) + 1]] = data.frame(
task_id = task$id,
learner_id = learner$id,
fold = i,
rmse = rmse
)
}
}
}
