library(mlr3)
library(mlr3learners)
library(mlr3tuning)
library(mlr3extralearners)
library(mlr3)
library(mlr3learners)
library(mlr3tuning) # Nécessaire pour l'AutoTuner
library(ggplot2)
# Chargement du package local
devtools::load_all()
# --- Préparation des données ---
data("mtcars", package = "datasets")
data("Orange", package = "datasets")
orange_clean = Orange
orange_clean$Tree = as.numeric(as.character(orange_clean$Tree))
t_mtcars = as_task_regr(mtcars, target = "mpg", id = "mtcars")
t_mtcars$col_roles$group = "cyl"
t_orange = as_task_regr(orange_clean, target = "age", id = "orange")
t_orange$col_roles$group = "Tree"
tasks = list(t_mtcars, t_orange)
# --- Configuration du k-NN avec AutoTuner ---
knn_lrn = lrn("regr.kknn", id = "kNN_Tuned")
# Définition de l'espace de recherche (k de 1 à 30)
search_space = ps(
k = p_int(lower = 1, upper = 30)
)
# Création de l'AutoTuner
knn_autotuner = auto_tuner(
tuner = tnr("grid_search", resolution = 30),
learner = knn_lrn,
resampling = rsmp("cv", folds = 3),
measure = msr("regr.rmse"),
search_space = search_space
)
# --- Liste des Learners ---
learners = list(
LearnerRegrMERF$new(),
lrn("regr.featureless", id = "Featureless"),
lrn("regr.cv_glmnet", id = "GLMnet"),
knn_autotuner # Ajout du k-NN optimisé
)
# --- Boucle de Benchmark ---
print("Démarrage du benchmark manuel")
results_list = list()
for (t in tasks) {
for (l in learners) {
# Gestion des IDs pour l'affichage
if (inherits(l, "LearnerRegrMERF")) l$id = "MERF"
print(paste("Test de", l$id, "sur", t$id))
set.seed(42)
split = partition(t, ratio = 0.8)
# Entraînement (L'AutoTuner gère le tuning interne ici)
l$train(t, split$train)
# Prédiction
p = l$predict(t, split$test)
# Score
rmse = p$score(msr("regr.rmse"))
results_list[[length(results_list) + 1]] = data.frame(
task_id = t$id,
learner_id = l$id,
regr.rmse = rmse
)
}
}
library(mlr3)
library(mlr3learners)
library(mlr3tuning)
library(ggplot2)
devtools::load_all()
# --- Données ---
data("mtcars", package = "datasets")
data("Orange", package = "datasets")
orange_clean = Orange
orange_clean$Tree = as.numeric(as.character(orange_clean$Tree))
t_mtcars = as_task_regr(mtcars, target = "mpg", id = "mtcars")
t_mtcars$col_roles$group = "cyl"
t_orange = as_task_regr(orange_clean, target = "age", id = "orange")
t_orange$col_roles$group = "Tree"
tasks = list(t_mtcars, t_orange)
# --- Configuration k-NN sécurisée ---
# On limite k à 10 pour éviter de dépasser le nombre d'observations (n)
knn_lrn = lrn("regr.kknn", id = "kNN_Tuned")
search_space = ps(k = p_int(lower = 1, upper = 10))
knn_autotuner = auto_tuner(
tuner = tnr("grid_search", resolution = 10),
learner = knn_lrn,
resampling = rsmp("cv", folds = 2), # Réduit à 2 folds car les données sont infimes
measure = msr("regr.rmse"),
search_space = search_space
)
# --- Liste des Learners ---
learners = list(
LearnerRegrMERF$new(),
lrn("regr.featureless", id = "Featureless"),
lrn("regr.cv_glmnet", id = "GLMnet"),
knn_autotuner
)
# --- Boucle de Benchmark avec Gestion d'Erreur ---
print("Démarrage du benchmark manuel")
results_list = list()
for (t in tasks) {
for (l in learners) {
if (inherits(l, "LearnerRegrMERF")) l$id = "MERF"
print(paste("Test de", l$id, "sur", t$id))
set.seed(42)
# On augmente un peu la taille du train (90%) pour aider MERF et le Tuning
split = partition(t, ratio = 0.9)
# Utilisation de tryCatch pour éviter que le script s'arrête si MERF échoue
result = tryCatch({
l$train(t, split$train)
p = l$predict(t, split$test)
rmse = p$score(msr("regr.rmse"))
data.frame(
task_id = t$id,
learner_id = l$id,
regr.rmse = rmse
)
}, error = function(e) {
message(paste("Erreur passée pour", l$id, ":", e$message))
return(NULL)
})
if (!is.null(result)) {
results_list[[length(results_list) + 1]] = result
}
}
}
final_results = do.call(rbind, results_list)
# --- Graphique ---
ggplot(final_results, aes(x = regr.rmse, y = learner_id, color = learner_id)) +
geom_point(size = 4) +
facet_grid(. ~ task_id, scales = "free_x") +
theme_bw() +
labs(title = "Benchmark (Correction Small Data)", x = "RMSE", y = "Algorithme")
ls
