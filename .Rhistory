set.seed(123)
data = data.frame(
x1   = runif(30),
x2   = runif(30),
grp  = rep(1:3, each = 10),
time = rep(1:10, times = 3),
y    = runif(30)
)
task = mlr3::as_task_regr(data, target = "y", id = "test")
task$col_roles$group   = "grp"
task$col_roles$order   = "time"
task$col_roles$feature = setdiff(task$feature_names, c("grp", "time"))
# Inspecte ce que mlr3 voit
print(task$col_names)   # "time" est-il dedans ?
print(task$col_roles)   # quel rôle a "time" ?
