library(mlr3)
set.seed(123)
data = data.frame(
x     = rnorm(60),
group = rep(1:6, each = 10),
y     = rnorm(60)
)
task = as_task_regr(data, target = "y")
task$col_roles$group   = "group"
task$col_roles$feature = "x"
# Diagnostics
print(task$groups)
print(task$col_roles)
