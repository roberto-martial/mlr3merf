library(LongituRF)
set.seed(123)
X = data.frame(x = rnorm(60))
X[] = lapply(X, as.numeric)
Y = rnorm(60)
Z = matrix(1, nrow = 60, ncol = 1)
id = as.integer(rep(1:6, each = 10))
time = as.numeric(seq_along(Y))
# Test direct
model = LongituRF::MERT(X = X, Y = Y, Z = Z, id = id, time = time, sto = 1e-3)
