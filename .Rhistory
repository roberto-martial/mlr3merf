library(LongituRF)
ls("package:LongituRF")
set.seed(123)
X    = as.data.frame(matrix(rnorm(60), ncol = 1))
Y    = rnorm(60)
Z    = matrix(1, nrow = 60, ncol = 1)
id   = as.integer(rep(1:6, each = 10))
time = as.numeric(1:60)
LongituRF::MERF(X = X, Y = Y, Z = Z, id = id, time = time, sto = 1e-3)
